DATABASE_URL="postgresql://studio:studio@localhost:5432/studio"
DIRECT_URL="postgresql://studio:studio@localhost:5432/studio"
STUDIO_API_KEY="dev-secret-key"
ADMIN_KEY="dev-admin-key"

# Auth0 用户登录(与 AgentPlanet 同租户;代码内已有默认值,需覆盖时取消注释)
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-ypufda63738rkary.us.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=QLV1xUDPecgw9mqYlViaw2OZ8DzeEGGI
# NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.agentplanet.org

# AgentPlanet Store 集成(付费角色授权用 Credits 结算;不配则付费角色暂不可购)
# AGENTPLANET_API_URL=https://api.agentplanet.org
# AGENTPLANET_INTERNAL_TOKEN=xxx

# 站内对话(嵌入式聊天代理 /api/chat → OpenClaw Gateway;不配则站内对话面板
# 提示「暂未开通」,不影响其余功能)。地址/token 取决于 comiclaw 迁移到独立
# 实例后的 Gateway 配置,迁移完成前先留空。
# OPENCLAW_GATEWAY_URL=https://your-gateway/v1
# OPENCLAW_GATEWAY_TOKEN=xxx
# OPENCLAW_GATEWAY_MODEL=customer
# CHAT_DAILY_MESSAGE_LIMIT=40

# 存储后端(默认 Vercel Blob)
# STORAGE_PROVIDER=blob

# 切换阿里云 OSS:
# STORAGE_PROVIDER=oss
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=xxx
# OSS_ACCESS_KEY_SECRET=xxx
# OSS_ENDPOINT=https://your-custom-cdn.com

# 切换腾讯云 COS:
# STORAGE_PROVIDER=cos
# COS_REGION=ap-guangzhou
# COS_BUCKET=your-bucket-1234567890
# COS_SECRET_ID=xxx
# COS_SECRET_KEY=xxx
# COS_ENDPOINT=https://your-custom-cdn.com
