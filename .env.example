DATABASE_URL="postgresql://studio:studio@localhost:5432/studio"
DIRECT_URL="postgresql://studio:studio@localhost:5432/studio"
STUDIO_API_KEY="dev-secret-key"
ADMIN_KEY="dev-admin-key"

# Auth0 用户登录(与 AgentPlanet 同租户;代码内已有默认值,需覆盖时取消注释)
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-ypufda63738rkary.us.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=QLV1xUDPecgw9mqYlViaw2OZ8DzeEGGI
# NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.agentplanet.org

# AgentPlanet Store 集成(付费角色授权用 Credits 结算;不配则付费角色暂不可购)
# AGENTPLANET_API_URL=https://api.agentplanet.org
# AGENTPLANET_INTERNAL_TOKEN=xxx

# 站内对话(嵌入式聊天代理 /api/chat → OpenClaw Gateway;不配则站内对话面板
# 提示「暂未开通」,不影响其余功能)。地址/token 取决于 comiclaw 迁移到独立
# 实例后的 Gateway 配置,迁移完成前先留空。
# OPENCLAW_GATEWAY_URL=https://your-gateway/v1
# OPENCLAW_GATEWAY_TOKEN=xxx
# OPENCLAW_GATEWAY_MODEL=customer
# CHAT_DAILY_MESSAGE_LIMIT=40
# CHAT_MIN_PROJECT_CREDITS=30

# AgentPlanet 按用量扣款(官方受信服务端 → /api/internal/wallet/charge)
# Backend 生产建议: SERVICE_CHARGE_ALLOWLIST=comiclaw-studio:comiclaw
# AGENTPLANET_AGENT_ID=<agentplanet-payee-agent-id>  # 必须在 AgentPlanet 存在;裸 "comiclaw" 会 Agent not found
# AGENTPLANET_CHARGE_SOURCE=comiclaw-studio

# ACN 内部生产线(private subnet + comiclaw-studio 建单 + 生产 Agent 接单;不上 Org)
# 建单身份必须是已注册的 comiclaw-studio agent(ACN 已废止 system:task-invite;勿用人类 ID)
# ACN_CHAT_* 为历史 env 名,值应指向 comiclaw-studio(不是「聊天人类」)
# ACN_API_URL=https://api.acnlabs.dev
# ACN_CHAT_AGENT_ID=90f884c1-f7fd-4e6f-b375-84521539648a   # comiclaw-studio
# ACN_CHAT_API_KEY=xxx                                      # 该 agent 的 key
# ACN_PROD_AGENT_ID=cd7ec18a-d72d-4ced-9b86-1c795f159db8    # 主 comiclaw 工人
# ACN_SUBNET_SLUG=comiclaw-internal
# 开放工人鉴权:工人用自己的 ACN Bearer 调 Studio;/agents/me 校验身份,
# 再按 X-Acn-Task-Id 绑定项目。STUDIO_API_KEY 仅官方编排/运维。
#
# --- 主 comiclaw 生产机(OpenClaw skill / shell;不是 Next 服务端) ---
# 详细运维见 docs/ops-production.md
# STUDIO_BASE_URL=https://studio.comiclaw.acnlabs.org
# STUDIO_API_KEY=xxx                 # 官方编排;也可用生产 ACN + 任务绑定
# ACN_SUBNET_SLUG=comiclaw-internal
# 常驻: acn listen --runtime http --wake-url http://127.0.0.1:<openclaw>/hooks/agent \
#          --wake-header 'Authorization: Bearer …'   # CLI ≥ 0.14.0；见 docs/acn-listen-runtime-cutover.md
# 兜底: skills/comiclaw-studio/scripts/production-worker.sh reconcile

# 价目表(Credits / 单位;charge 只接受 action+units,金额由服务端算)
# PRICE_SCRIPT_GEN=0
# PRICE_ASSET_GENERATE=5          # 每张设定图
# PRICE_SHOT_GENERATE=8           # 每张分镜图
# PRICE_VIDEO_GENERATE=30         # 每秒视频
# PRICE_POST_PRODUCTION=10        # 每次后期

# 存储后端(默认 Vercel Blob)
# STORAGE_PROVIDER=blob

# 切换阿里云 OSS:
# STORAGE_PROVIDER=oss
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=xxx
# OSS_ACCESS_KEY_SECRET=xxx
# OSS_ENDPOINT=https://your-custom-cdn.com

# 切换腾讯云 COS:
# STORAGE_PROVIDER=cos
# COS_REGION=ap-guangzhou
# COS_BUCKET=your-bucket-1234567890
# COS_SECRET_ID=xxx
# COS_SECRET_KEY=xxx
# COS_ENDPOINT=https://your-custom-cdn.com
