generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Pooler URL — used by Vercel serverless at runtime
  directUrl = env("DIRECT_URL")         // Direct URL — used by prisma migrate at build time
}

// ---------- 项目 ----------

// 工作流固定五阶段:剧本 -> 资产 -> 分镜 -> 成片 -> 发行
// 阶段不建表,作为项目上的状态字段
model Project {
  id          String   @id @default(cuid())
  shareToken  String   @unique @default(cuid()) // 客户免登录访问令牌
  name        String // 项目名,如「XX智能体 15s 宣传短视频」
  clientName  String? // 客户名称
  agentName   String? // 被宣传的智能体名称
  description String?
  coverUrl    String? // 项目封面图
  ownerUserId String? // 客户的 AgentPlanet 账号(Auth0 sub,如 auth0|xxx);登录自动认领或 agent 创建时传入
  isPrivate   Boolean @default(false) // 私密模式:开启后仅主人(和管理员)可查看
  statusNote  String? // 实时状态(agent 推送,如「正在生成分镜 3/9…」),阶段完成后清空
  currentStage String  @default("SCRIPT") // SCRIPT | ASSETS | STORYBOARD | FILM | RELEASE | DONE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scriptVersions ScriptVersion[]
  assets         Asset[]
  shots          Shot[]
  filmVersions   FilmVersion[]
  releases       Release[]
  work           Work?
  comments       Comment[]
  castingLicenses CastingLicense[]
  generationCharges GenerationChargeRef[]

  @@index([ownerUserId])
}

// ---------- 剧本 ----------

model ScriptVersion {
  id        String   @id @default(cuid())
  projectId String
  version   Int // 从 1 递增
  title     String?
  logline   String? // 一句话梗概
  content   String // 剧本正文(Markdown,分场)
  changeLog String? // 本版改动说明
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
}

// ---------- 资产(角色/场景/道具) ----------

model Asset {
  id          String   @id @default(cuid())
  projectId   String
  type        String // CHARACTER | SCENE | PROP
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions AssetVersion[]
  shotRefs ShotAsset[]
}

model AssetVersion {
  id        String   @id @default(cuid())
  assetId   String
  version   Int
  imageUrl  String // 设定图
  audioUrl  String? // 音色试听(角色资产的声音样本)
  notes     String? // 本版设计说明
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
}

// ---------- 分镜 ----------

model Shot {
  id              String   @id @default(cuid())
  projectId       String
  order           Int // 镜头序号,从 1 开始
  title           String? // 镜头名,如「开场:LOGO 浮现」
  duration        Float? // 时长(秒)
  dialogue        String? // 台词 / 旁白
  action          String? // 画面描述
  prompt          String? // 生成提示词(输入侧,供专业用户查看与追溯)
  selectedVersion Int? // 客户选定的候选版本(抽卡选片)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  ShotVersion[]
  assetRefs ShotAsset[]

  @@unique([projectId, order])
}

model ShotVersion {
  id        String   @id @default(cuid())
  shotId    String
  version   Int
  mediaUrl  String // 画面(图或视频片段)
  mediaType String   @default("IMAGE") // IMAGE | VIDEO
  notes     String?
  createdAt DateTime @default(now())

  shot Shot @relation(fields: [shotId], references: [id], onDelete: Cascade)

  @@unique([shotId, version])
}

// 分镜引用的资产
model ShotAsset {
  shotId  String
  assetId String

  shot  Shot  @relation(fields: [shotId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([shotId, assetId])
}

// ---------- 成片 ----------

model FilmVersion {
  id        String   @id @default(cuid())
  projectId String
  version   Int
  videoUrl  String
  duration  Float? // 秒
  notes     String? // 本版剪辑说明
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@unique([projectId, version])
}

// ---------- 时间码批注 ----------

// 客户对成片版本的时间码反馈(Frame.io 式);agent 拉取后精确返工
model Comment {
  id            String   @id @default(cuid())
  projectId     String
  filmVersionId String
  timecode      Float? // 秒;空表示针对整版的整体意见
  content       String
  authorSub     String // 发表者的 AgentPlanet 账号(Auth0 sub)
  authorName    String? // 展示名
  status        String   @default("OPEN") // OPEN | RESOLVED
  createdAt     DateTime @default(now())

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filmVersion FilmVersion @relation(fields: [filmVersionId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

// ---------- 智能体角色(数字人名录 / 选角市场) ----------

// 独立于项目的数字人角色,可复用:主演自己的宣传片、参演他人短剧。
// 两种来源:comiclaw 直接创建数字人 / 从项目资产发布。
model AgentCharacter {
  id          String   @id @default(cuid())
  name        String // 角色名 / 数字人名
  tagline     String? // 一句话简介
  persona     String? // 人设描述
  styleTags   String? // 风格标签,逗号分隔(如「写实,都市,专业」)
  imageUrl      String // 主形象图
  audioUrl      String? // 音色试听
  gallery       String? // 附加形象图 URL,逗号分隔(多视图/变装)
  introVideoUrl String? // 角色介绍视频(数字人可视化交互展示)

  // 关联的 ACN 智能体信息(第一步由创建方传入,后续可自动拉取)
  acnAgentId    String? // ACN agent_id
  agentName     String? // 智能体名称
  agentSummary  String? // 智能体简介
  agentUrl      String? // 智能体主页(AgentPlanet / 官网)

  ownerUserId     String? // 所属客户(Auth0 sub)
  sourceProjectId String? // 来源项目(从资产发布时填写;直接创建为空)
  isPublic        Boolean @default(true) // 是否在角色市场公开
  openForCasting  Boolean @default(false) // 是否开放参演他人作品
  licensePoints   Int     @default(0) // 授权费(AgentPlanet Credits/项目);0 = 免费授权
  storeProductId  String? // AgentPlanet Store 的 agent_asset 商品 id(付费角色上架后回填)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  castIn   WorkCast[]
  licenses CastingLicense[]

  @@index([isPublic])
  @@index([ownerUserId])
}

// 选角授权:把角色市场的数字人授权给某个项目使用。
// 免费角色即时授予;付费角色经 AgentPlanet Store 扣 Credits 后授予,
// 收益(扣平台佣金后)进角色所属智能体的钱包。
model CastingLicense {
  id           String   @id @default(cuid())
  characterId  String
  projectId    String
  licenseeSub  String // 发起授权的客户(Auth0 sub)
  points       Int      @default(0) // 成交 Credits(快照)
  status       String   @default("GRANTED") // GRANTED | PENDING_PAYMENT
  storeOrderId String?  @unique // AgentPlanet Store 订单 id(付费授权)
  createdAt    DateTime @default(now())

  character AgentCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([characterId, projectId])
}

// 参演关系:作品 ↔ 角色(主演/参演)
model WorkCast {
  workId      String
  characterId String

  work      Work           @relation(fields: [workId], references: [id], onDelete: Cascade)
  character AgentCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([workId, characterId])
}

// ---------- 平台作品(推荐 / 短剧) ----------

// 发行完成的内容回流为平台作品;短剧可含多集
model Work {
  id          String   @id @default(cuid())
  kind        String // VIDEO(短视频) | SERIES(短剧)
  category    String? // 短剧子类,目前仅「漫剧」
  title       String
  description String?
  coverUrl    String?
  videoUrl    String? // VIDEO 类作品的正片
  authorName  String? // 创作者(客户 / 智能体名)
  projectId   String?  @unique // 来源 studio 项目(同步发布时填写)
  publishedAt DateTime @default(now())

  project  Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodes Episode[]
  cast     WorkCast[]
}

model Episode {
  id       String  @id @default(cuid())
  workId   String
  order    Int
  title    String?
  videoUrl String
  duration Float?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, order])
}

// ---------- 发行 ----------

model Release {
  id          String    @id @default(cuid())
  projectId   String
  platform    String // 抖音 | 视频号 | B站 | ...
  url         String?
  status      String    @default("PENDING") // PENDING | PUBLISHED
  publishedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ---------- 生成任务 ↔ 扣款交易 关联 ----------

// 不是账本:Credits 的余额、入账、幂等防重全部由 AgentPlanet 的
// /api/internal/wallet/charge 权威负责(它自己写 Transaction、自己按
// idempotency_key 去重)。这张表只记"这次生成动作(jobId)对应哪笔
// AgentPlanet 交易",纯粹是本地排障用的关联指针——查一个项目做了哪些
// 生成动作、对应哪个 transactionId——不重复维护"扣了多少钱"这份真相,
// 避免跟 AgentPlanet 的权威记录双写不一致。
model GenerationChargeRef {
  id            String   @id @default(cuid())
  projectId     String
  userSub       String // 付款客户(Auth0 sub),便于按用户排查,不是余额字段
  jobId         String   @unique // 即传给 AgentPlanet 的 idempotency_key
  amount        Int? // 本次请求金额,仅供排障参考;权威金额见 AgentPlanet Transaction
  action        String? // script_gen | asset_generate | shot_generate | video_generate | post_production
  provider      String? // 上游服务,如 seedance / jimeng
  status        String // SUCCESS | INSUFFICIENT_BALANCE | ERROR
  transactionId String? // AgentPlanet 返回的 transaction_id(仅 SUCCESS 有)
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userSub])
}

// ---------- 站内对话(comiclaw 嵌入式聊天) ----------

// 每人每天的消息计数,用于限额。用 DB 而不是内存计数,因为 Vercel
// serverless 实例是短生命周期、多实例的,内存计数在实例间不一致。
model ChatUsage {
  userSub String
  day     String // UTC 日期,格式 YYYY-MM-DD
  count   Int    @default(0)

  updatedAt DateTime @updatedAt

  @@id([userSub, day])
}
